rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // Both designated email addresses are treated as super admins
      return isAuthenticated() && 
             (request.auth.token.email.lower() == 'zowamarketing@gmail.com' || 
              request.auth.token.email.lower() == 'animalboxclinic@gmail.com');
    }

    // Standard staff check - allows admins or users with role set to 'staff' or 'doctor' in their profile
    function isStaff() {
      return isAdmin() || 
             (isAuthenticated() && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'doctor', 'staff', 'vet']);
    }

    // ===============================================================
    // Global Access Rules
    // ===============================================================

    // For now, granting full transition access to the two admin accounts
    // and staff as we stabilize the new database instance.
    match /{document=**} {
      allow read, write: if isStaff();
    }
    
    // Specifically protect the users collection to ensure admins can manage it
    match /users/{userId} {
      allow read, write: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }
  }
}
